# Baken — environment. Copy to .env and fill in. (.env is gitignored.)

# Public hostname Caddy serves and requests a TLS certificate for.
# Point this DNS name at your server first; ports 80 and 443 must be reachable.
BAKEN_HOST=baken.example.com

# Optional fallback device id for the Overland bridge. Leave empty and set the
# "Device ID" inside the Overland app instead (to the Traccar device identifier).
BAKEN_DEFAULT_DEVICE_ID=
