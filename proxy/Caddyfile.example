# Baken — Caddy reverse proxy. Copy to proxy/Caddyfile.
# Automatic HTTPS: Caddy obtains and renews a Let's Encrypt cert for BAKEN_HOST.
#
# Everything is in `handle` blocks so routing is unambiguous (matched in source
# order). Don't mix bare directives with handle blocks — the catch-all handle
# below would otherwise swallow /api requests.

{$BAKEN_HOST} {
	encode gzip

	# --- Security headers (all responses) ------------------------------------
	# The viewer runs fully under this CSP (no inline scripts/handlers); style-src
	# keeps 'unsafe-inline' for the app's inline style=. Adjust the tile hosts in
	# img-src/connect-src to the map styles you enable in viewer/config.js.
	header {
		X-Frame-Options "DENY"
		X-Content-Type-Options "nosniff"
		Referrer-Policy "strict-origin-when-cross-origin"
		Content-Security-Policy "default-src 'self'; script-src 'self'; worker-src 'self' blob:; style-src 'self' 'unsafe-inline'; img-src 'self' data: blob: https://tile.openstreetmap.org https://*.basemaps.cartocdn.com https://*.tile.openstreetmap.fr https://tiles.openfreemap.org; connect-src 'self' https://tiles.openfreemap.org; font-src 'self'; frame-ancestors 'none'; base-uri 'self'; object-src 'none'"
	}

	# Note: no access log is configured here, so the token in
	# GET /api/session?token=… is never written to disk. If you add a `log`
	# directive, filter the `token` query parameter out of the logged URI.

	# --- REST API + WebSocket -> Traccar -------------------------------------
	# Location data must never be cached by browsers or the service worker.
	# Caddy's reverse_proxy upgrades WebSockets automatically (/api/socket).
	handle /api/* {
		header Cache-Control "no-store"
		reverse_proxy traccar:8082
	}

	# --- Device publish (OsmAnd protocol: Traccar Client app) ----------------
	handle_path /track/* {
		reverse_proxy traccar:5055
	}

	# --- Overland (iOS) -> PHP bridge -> Traccar OsmAnd ----------------------
	handle /overland {
		root * /srv/bridge
		rewrite * /overland.php
		php_fastcgi bridge:9000
	}

	# --- Optional: address lookup via your own Nominatim ---------------------
	# The viewer can show street names (config.js showAddress:true). That needs
	# a reverse-geocoder. If you run one, uncomment and point these at it;
	# otherwise set showAddress:false in viewer/config.js.
	# handle_path /geocode/* {
	# 	reverse_proxy nominatim:8080
	# }
	# handle_path /geosearch/* {
	# 	reverse_proxy nominatim:8080
	# }

	# --- Viewer (static PWA) — everything else -------------------------------
	handle {
		root * /srv/viewer
		file_server
	}
}
