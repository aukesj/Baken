<?xml version='1.0' encoding='UTF-8'?>
<!DOCTYPE properties SYSTEM 'http://java.sun.com/dtd/properties.dtd'>

<!--
  Baken — Traccar configuration template.
  Copy this to traccar/traccar.xml and adjust if needed. The defaults below are
  sensible for a small family/group on the embedded H2 database.
-->
<properties>

    <entry key='config.default'>./conf/default.xml</entry>

    <!-- Database. Default: embedded H2 file under ./data — fine for small
         groups. For many users/devices, switch to MySQL/Postgres (see Traccar
         docs) and point this at it. -->
    <entry key='database.driver'>org.h2.Driver</entry>
    <entry key='database.url'>jdbc:h2:./data/database</entry>
    <entry key='database.user'>sa</entry>
    <entry key='database.password'></entry>

    <!-- Web UI + REST API. Served behind the reverse proxy, so no host port is
         needed; the proxy talks to traccar:8082 over the Docker network. -->
    <entry key='web.address'>0.0.0.0</entry>
    <entry key='web.port'>8082</entry>

    <!-- Session cookies only over HTTPS (the proxy terminates TLS). -->
    <entry key='web.cookie.secure'>true</entry>

    <!-- Only let fresh fixes through, so a phone can't flush hours of stale
         offline buffer into your live view. -->
    <entry key='filter.enable'>true</entry>
    <entry key='filter.future'>3600</entry>
    <entry key='filter.duplicate'>true</entry>

</properties>
